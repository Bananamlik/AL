        // ==========================================
        // GAME LOGIC
        // ==========================================
        function switchTurn() {
            clearInterval(gameState._turnTimer);
            const countdown = document.getElementById('turn-countdown');
            if (countdown) countdown.style.display = 'none';
            gameState.isFollowing = true;

            const prevPs = gameState.currentPlayer === 1 ? gameState.player1 : gameState.player2;
            prevPs.ink = Math.min(CONFIG.inkMax, prevPs.ink + CONFIG.inkRechargePerTurn);

            gameState.currentPlayer = gameState.currentPlayer === 1 ? 2 : 1;
            gameState.turn++;
            playSound('turn');
            gameState.isPlanning = true;
            gameState.hasShot = false;
            elements.avatarP1.classList.toggle('active', gameState.currentPlayer === 1);
            elements.avatarP2.classList.toggle('active', gameState.currentPlayer === 2);
