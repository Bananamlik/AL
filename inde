        let volDragging = false;
        const volSlider = document.getElementById('volume-slider');
        const volFill   = document.getElementById('volume-fill');
        function updateVolume(e) {
            const rect = volSlider.getBoundingClientRect();
            const pct = Math.max(0, Math.min(1, (e.clientX - rect.left) / rect.width));
            volFill.style.width = `${pct * 100}%`;
            gameState.settings.volume = pct;
        }
        volSlider.addEventListener('mousedown', e => { volDragging = true; updateVolume(e); });
        document.addEventListener('mousemove', e => { if (volDragging) updateVolume(e); });
        document.addEventListener('mouseup', () => { volDragging = false; });

        // ==========================================
        // ANIMATION LOOP
        // ==========================================
        const clock = new THREE.Clock();
        let lastSecond = 0;
        let gameActive = false;

        function animate() {
            requestAnimationFrame(animate);
            const deltaTime = Math.min(clock.getDelta(), 0.1);
            const elapsed   = clock.getElapsedTime();

            if (gameActive) {
                if (Math.floor(elapsed) > lastSecond) {
                    lastSecond = Math.floor(elapsed);
                    updateTimer();
                }
            }

            players.forEach(p => applyPhysicsForces(p.body));
            world.step(deltaTime);

            players.forEach((player, idx) => {
                player.mesh.position.copy(player.body.position);
                player.mesh.quaternion.copy(player.body.quaternion);

                if (!gameActive) return;

                const speed = player.body.velocity.length();
                if (speed > CONFIG.trailSpeedThreshold && gameState.settings.showTrails) {
                    const curPos = new THREE.Vector3().copy(player.body.position);
                    const d = curPos.distanceTo(player.lastTrailPos);
                    if (d > CONFIG.trailSpacing) {
                        addTrail(idx, curPos);
                        player.lastTrailPos.copy(curPos);
                        if (idx === 0) gameState.player1.distance += d;
                        else           gameState.player2.distance += d;
                    }
                }

                if (gameState.hasShot && !gameState.isPlanning) {
                    if (idx === gameState.currentPlayer - 1 && speed < 0.3) {
                        setTimeout(() => switchTurn(), 500);
                        gameState.isPlanning = true;
                    }
                }
            });

            if (gameState.settings.cameraRotation) {
                cloudGroup.rotation.y += 0.0001;
            }
            if (isDragging) aimGroup.position.copy(players[gameState.currentPlayer - 1].mesh.position);

            controls.target.set(0, 0, 0);
            if (gameActive && gameState.isFollowing && !gameState.isRotating) {
                const ap = players[gameState.currentPlayer - 1];
                const upVec = ap.mesh.position.clone().normalize();
                const spd   = ap.body.velocity.length();
                const targetDist = spd > 2 ? 18 : spd > 0.5 ? 12 : 8;
                camera.position.lerp(upVec.multiplyScalar(targetDist), 0.06);
            }
            controls.update();
            renderer.render(scene, camera);
        }

        window.addEventListener('resize', () => {
            camera.aspect = window.innerWidth / window.innerHeight;
            camera.updateProjectionMatrix();
            renderer.setSize(window.innerWidth, window.innerHeight);
        });

        // ==========================================
        // TITLE SCREEN + GAME START
        // ==========================================
        let selectedDuration = 180;

        window.setDuration = function(sec) {
            selectedDuration = sec;
            ['dur-1','dur-3','dur-5'].forEach(id => {
                const el = document.getElementById(id);
                if (!el) return;
                el.style.background = 'rgba(255,255,255,0.15)';
                el.style.color = 'white';
                el.style.borderColor = 'rgba(255,255,255,0.4)';
            });
            const map = { 60: 'dur-1', 180: 'dur-3', 300: 'dur-5' };
            const active = document.getElementById(map[sec]);
            if (active) {
                active.style.background = 'rgba(255,255,255,0.9)';
                active.style.color = '#FF4757';
                active.style.borderColor = 'white';
            }
        };

        window.startFromTitle = function() {
            const btn = document.getElementById('btn-play');
            if (btn && btn.disabled) return;

            if (!biomeReady) {
                if (btn) { btn.textContent = '⏳ Loading map...'; btn.disabled = true; }
                const prevCb = gameReadyCallback;
                gameReadyCallback = () => {
                    if (prevCb) prevCb();
                    window.startFromTitle();
                };
                return;
            }

            const ts = document.getElementById('title-screen');
            if (ts) {
                ts.style.transition = 'opacity 0.4s';
                ts.style.opacity = '0';
                setTimeout(() => { if (ts.parentNode) ts.parentNode.removeChild(ts); }, 450);
            }

            CONFIG.gameDuration = selectedDuration;
            gameState.timeRemaining = selectedDuration;

            const m = Math.floor(selectedDuration / 60);
            const s = selectedDuration % 60;
            elements.timer.textContent = `${m}:${s.toString().padStart(2,'0')}`;

            gameActive = true;
            lastSecond = Math.floor(clock.getElapsedTime());

            elements.turnText.textContent = "Player 1's Turn";
            elements.turnIndicator.classList.add('show');
            setTimeout(() => elements.turnIndicator.classList.remove('show'), 2000);
            setTimeout(startTurnTimer, 600);
        };

        function startTurnTimer() {
            clearInterval(gameState._turnTimer);
            let remaining = CONFIG.turnTimeLimit;
            const countdown = document.getElementById('turn-countdown');
            if (countdown) {
                countdown.textContent = remaining;
                countdown.style.color = '#2D3436';
                countdown.style.display = 'flex';
            }
            gameState._turnTimer = setInterval(() => {
                remaining--;
                if (countdown) {
                    countdown.textContent = remaining;
                    if (remaining <= 10) {
                        countdown.style.color = '#FF4757';
                        countdown.style.transform = remaining % 2 === 0
                            ? 'translateX(-50%) scale(1.15)'
                            : 'translateX(-50%) scale(1.0)';
                    } else {
                        countdown.style.color = '#2D3436';
                        countdown.style.transform = 'translateX(-50%) scale(1.0)';
                    }
                }
                if (remaining <= 0) {
                    clearInterval(gameState._turnTimer);
                    if (countdown) {
                        countdown.style.display = 'none';
                        countdown.style.transform = 'translateX(-50%) scale(1.0)';
                    }
                    if (gameState.isPlanning) switchTurn();
                }
            }, 1000);
        }

        // ==========================================
        // BOOTSTRAP
        // ==========================================
        const loadingEl = document.getElementById('loading');
        if (loadingEl) {
            loadingEl.classList.add('hidden');
            setTimeout(() => { if (loadingEl.parentNode) loadingEl.style.display = 'none'; }, 550);
        }

        animate();
    </script>
</body>
</html>
