    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import * as CANNON from 'cannon-es';

        // ==========================================
        // GAME CONFIGURATION
        // ==========================================
        const CONFIG = {
            earthRadius:       4,
            playerRadius:      0.12,
            gravity:           120,
            mass:              5,
            damping:           0.55,
            shootForce:        135,
            coriolisFactor:    3.5,

            gameDuration:      180,
            turnTimeLimit:     30,

            trailSpacing:      0.08,
            trailSpeedThreshold: 0.3,
            captureRadius:     1.0,
            minLoopLength:     8,
            LAND_THRESHOLD:    25,

            inkMax:            100,
            inkLandCost:       0.4,
            inkOceanPenalty:   20,
            inkRechargePerTurn: 15,
        };

        // ==========================================
        // GAME STATE
        // ==========================================
        const gameState = {
            currentPlayer: 1,
            turn: 1,
            timeRemaining: CONFIG.gameDuration,
            isPlanning: true,
            hasShot: false,
            player1: { territory: 0, shots: 0, distance: 0, loops: 0, ink: 100 },
            player2: { territory: 0, shots: 0, distance: 0, loops: 0, ink: 100 },
            collisions: 0,
            isRotating: false,
            isFollowing: true,
            settings: { soundEnabled: true, volume: 0.7, cameraRotation: true, showTrails: true }
        };

        // ==========================================
        // SOUND SYSTEM
        // ==========================================
        const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

        function playSound(type) {
            if (!gameState.settings.soundEnabled) return;
            if (audioCtx.state === 'suspended') audioCtx.resume();
            const osc = audioCtx.createOscillator();
            const gain = audioCtx.createGain();
            osc.connect(gain);
            gain.connect(audioCtx.destination);
            const now = audioCtx.currentTime;

            if (type === 'charge') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(200, now);
                osc.frequency.linearRampToValueAtTime(400, now + 0.1);
                gain.gain.setValueAtTime(0.05, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.1);
                osc.start(now); osc.stop(now + 0.1);
            } else if (type === 'shoot') {
                osc.type = 'triangle';
                osc.frequency.setValueAtTime(300, now);
                osc.frequency.exponentialRampToValueAtTime(50, now + 0.2);
                gain.gain.setValueAtTime(0.3, now);
                gain.gain.exponentialRampToValueAtTime(0.01, now + 0.2);
                osc.start(now); osc.stop(now + 0.2);
            } else if (type === 'turn') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(600, now);
                osc.frequency.exponentialRampToValueAtTime(800, now + 0.1);
                gain.gain.setValueAtTime(0.1, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.3);
                osc.start(now); osc.stop(now + 0.3);
            } else if (type === 'capture') {
                osc.type = 'sine';
                osc.frequency.setValueAtTime(440, now);
                osc.frequency.exponentialRampToValueAtTime(880, now + 0.35);
                gain.gain.setValueAtTime(0.25, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.5);
                osc.start(now); osc.stop(now + 0.5);
            } else if (type === 'steal') {
                osc.type = 'sawtooth';
                osc.frequency.setValueAtTime(660, now);
                osc.frequency.exponentialRampToValueAtTime(220, now + 0.4);
                gain.gain.setValueAtTime(0.2, now);
                gain.gain.linearRampToValueAtTime(0, now + 0.4);
                osc.start(now); osc.stop(now + 0.4);
            }
        }

        // ==========================================
        // SCENE SETUP
        // ==========================================
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x0a0a1e);

        const camera = new THREE.PerspectiveCamera(50, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(0, 5, 12);

        const renderer = new THREE.WebGLRenderer({ antialias: true, alpha: false });
        renderer.setSize(window.innerWidth, window.innerHeight);
        renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

        const canvas = renderer.domElement;
        canvas.style.cssText = 'position:fixed;top:0;left:0;width:100%;height:100%;z-index:0;display:block;';
        document.body.insertBefore(canvas, document.body.firstChild);

        // ==========================================
        // STARFIELD
        // ==========================================
        (function addStars() {
            const geo = new THREE.BufferGeometry();
            const n = 2000;
            const pos = new Float32Array(n * 3);
            for (let i = 0; i < n * 3; i++) pos[i] = (Math.random() - 0.5) * 400;
            geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
            scene.add(new THREE.Points(geo, new THREE.PointsMaterial({ color: 0xffffff, size: 0.4, sizeAttenuation: true })));
        })();

        // ==========================================
        // LIGHTING
        // ==========================================
        scene.add(new THREE.AmbientLight(0xffffff, 0.9));
        const dirLight = new THREE.DirectionalLight(0xffffff, 0.5);
        dirLight.position.set(5, 10, 7);
        scene.add(dirLight);

        // ==========================================
        // PHYSICS WORLD
        // ==========================================
        const world = new CANNON.World();
        world.gravity.set(0, 0, 0);
        world.broadphase = new CANNON.NaiveBroadphase();
        world.solver.iterations = 20;

        const physicsMaterial = new CANNON.Material('physics');
        world.addContactMaterial(new CANNON.ContactMaterial(
            physicsMaterial, physicsMaterial,
            { friction: 0.3, restitution: 0.2 }
        ));

        // ==========================================
        // EARTH
        // ==========================================
        const earthBody = new CANNON.Body({
            mass: 0,
            shape: new CANNON.Sphere(CONFIG.earthRadius),
            material: physicsMaterial
        });
        world.addBody(earthBody);

        const earthTexture = new THREE.TextureLoader().load(
            'https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/planets/earth_atmos_2048.jpg'
        );

        const earthMaterial = new THREE.ShaderMaterial({
            uniforms: { map: { value: earthTexture } },
            vertexShader: `varying vec2 vUv; void main(){ vUv=uv; gl_Position=projectionMatrix*modelViewMatrix*vec4(position,1.0); }`,
            fragmentShader: `
                uniform sampler2D map; varying vec2 vUv;
                void main(){
                    vec4 t = texture2D(map, vUv);
                    vec3 color = vec3(0.4, 0.7, 1.0);
                    float br = t.r + t.g + t.b;
                    if(t.b <= t.r + 0.098){
                        if(br > 2.1)      color = vec3(0.94, 0.96, 0.97);
                        else if(t.r>t.g)  color = vec3(1.0,  0.85, 0.56);
                        else              color = vec3(0.45, 0.82, 0.49);
                    }
                    gl_FragColor = vec4(color, 1.0);
                }
            `
        });

        const earthMesh = new THREE.Mesh(new THREE.SphereGeometry(CONFIG.earthRadius, 64, 64), earthMaterial);
        scene.add(earthMesh);
        earthMesh.add(new THREE.Mesh(
            new THREE.SphereGeometry(CONFIG.earthRadius + 0.08, 64, 64),
            new THREE.MeshBasicMaterial({ color: 0x2D3436, side: THREE.BackSide })
        ));

        // ==========================================
        // TERRITORY OVERLAY SYSTEM
        // ==========================================
        let biomeData = null, biomeWidth = 0, biomeHeight = 0;
        let ownershipMap = null;
        let totalLandPixels = 0;
        const playerLandPixels = [0, 0];

        let overlayCanvas, overlayCtx, overlayTexture, overlayMesh;

        const TERR_COLOR = [
            { r: 255, g: 71,  b: 87,  a: 160 },
            { r: 83,  g: 82,  b: 237, a: 160 },
        ];

        function isLandPixelSingle(gx, gy) {
            if (!biomeData) return true;
            if (gx < 0 || gx >= biomeWidth || gy < 0 || gy >= biomeHeight) return false;
            const idx = (gy * biomeWidth + gx) * 4;
            const brightness = (biomeData[idx] + biomeData[idx+1] + biomeData[idx+2]) / 3;
            return brightness < 80;
        }

        function isLandPixel(gx, gy) {
            if (!biomeData) return true;
            let landCount = 0, total = 0;
            for (let dy = -1; dy <= 1; dy++) {
                for (let dx = -1; dx <= 1; dx++) {
                    const x = gx + dx, y = gy + dy;
                    if (x < 0 || x >= biomeWidth || y < 0 || y >= biomeHeight) continue;
                    const idx = (y * biomeWidth + x) * 4;
                    total++;
                    const brightness = (biomeData[idx] + biomeData[idx+1] + biomeData[idx+2]) / 3;
                    if (brightness < 80) landCount++;
                }
            }
            return landCount > total / 2;
        }

        function isLandAtUV(u, v) {
            if (!biomeData) return true;
            const gx = Math.floor(u * (biomeWidth - 1));
            const gy = Math.floor(v * (biomeHeight - 1));
            return isLandPixel(gx, gy);
        }

        function getUV(pos) {
            const n = pos.clone().normalize();
            const u = ((Math.atan2(n.z, -n.x) / (2 * Math.PI)) + 1.0) % 1.0;
            const v = 0.5 - Math.asin(Math.max(-1, Math.min(1, n.y))) / Math.PI;
            return { u, v };
        }

        function getBiome(pos) {
            const { u, v } = getUV(pos);
            return isLandAtUV(u, v) ? 'LAND' : 'OCEAN';
        }

        function initOverlay() {
            overlayCanvas = document.createElement('canvas');
            overlayCanvas.width  = biomeWidth;
            overlayCanvas.height = biomeHeight;
            overlayCtx = overlayCanvas.getContext('2d', { willReadFrequently: true });

            ownershipMap = new Uint8Array(biomeWidth * biomeHeight);

            totalLandPixels = 0;
            (function countLandAsync() {
                const CHUNK = 80000;
                let i = 0, count = 0;
                function step() {
                    const end = Math.min(i + CHUNK, biomeWidth * biomeHeight);
                    for (; i < end; i++) {
                        const px = i % biomeWidth, py = Math.floor(i / biomeWidth);
                        if (isLandPixelSingle(px, py)) count++;
                    }
                    if (i < biomeWidth * biomeHeight) {
                        requestAnimationFrame(step);
                    } else {
                        totalLandPixels = count;
                        console.log(`[GlobeStriker] totalLandPixels 계산 완료: ${count}`);
                        updateTerritoryScores();
                    }
                }
                requestAnimationFrame(step);
            })();

            overlayTexture = new THREE.CanvasTexture(overlayCanvas);
            overlayMesh = new THREE.Mesh(
                new THREE.SphereGeometry(CONFIG.earthRadius + 0.012, 64, 64),
                new THREE.MeshBasicMaterial({
                    map: overlayTexture,
                    transparent: true,
                    depthWrite: false,
                    opacity: 1.0,
                })
            );
            scene.add(overlayMesh);
        }

        function isBorderPixel(oi) {
            const gx = oi % biomeWidth, gy = Math.floor(oi / biomeWidth);
            const owner = ownershipMap[oi];
            for (const [dx, dy] of [[-1,0],[1,0],[0,-1],[0,1]]) {
                const nx = gx + dx, ny = gy + dy;
                if (nx < 0 || nx >= biomeWidth || ny < 0 || ny >= biomeHeight) continue;
                if (ownershipMap[ny * biomeWidth + nx] !== owner) return true;
            }
            return false;
        }

        function repaintRegion(minX, minY, maxX, maxY) {
            const w = maxX - minX + 1, h = maxY - minY + 1;
            const imgData = overlayCtx.getImageData(minX, minY, w, h);
            const data = imgData.data;
            for (let ly = 0; ly < h; ly++) {
                for (let lx = 0; lx < w; lx++) {
                    const oi = (minY + ly) * biomeWidth + (minX + lx);
                    const owner = ownershipMap[oi];
                    const pi = (ly * w + lx) * 4;
                    if (owner > 0) {
                        const c = TERR_COLOR[owner - 1];
                        const border = isBorderPixel(oi);
                        data[pi]   = c.r;
                        data[pi+1] = c.g;
                        data[pi+2] = c.b;
                        data[pi+3] = border ? 220 : c.a;
                    } else {
                        data[pi+3] = 0;
                    }
                }
            }
            overlayCtx.putImageData(imgData, minX, minY);
            overlayTexture.needsUpdate = true;
        }

        function repaintOverlay() {
            repaintRegion(0, 0, biomeWidth - 1, biomeHeight - 1);
        }

        function updateTerritoryScores() {
            if (totalLandPixels === 0) return;
            gameState.player1.territory = playerLandPixels[0] / totalLandPixels * 100;
            gameState.player2.territory = playerLandPixels[1] / totalLandPixels * 100;
            const p1pct = gameState.player1.territory;
            const p2pct = gameState.player2.territory;
            elements.territoryP1.textContent = `${p1pct.toFixed(2)}%`;
            elements.territoryP2.textContent = `${p2pct.toFixed(2)}%`;
            const MAX_DISPLAY = 40;
            const bar1 = document.getElementById('territory-bar-p1');
            const bar2 = document.getElementById('territory-bar-p2');
            if (bar1) bar1.style.width = `${Math.min(100, p1pct / MAX_DISPLAY * 100)}%`;
            if (bar2) bar2.style.width = `${Math.min(100, p2pct / MAX_DISPLAY * 100)}%`;
        }

        function normalizeUVs(uvPoints) {
            if (uvPoints.length === 0) return uvPoints;
            const ref = uvPoints[0].u;
            return uvPoints.map(p => {
                let u = p.u;
                if (u - ref >  0.5) u -= 1.0;
                if (u - ref < -0.5) u += 1.0;
                return { u, v: p.v };
            });
        }

        function createTerritoryArea(points, playerIdx) {
            if (points.length < 3 || !biomeData || !ownershipMap) return;

            const otherIdx = playerIdx === 0 ? 1 : 0;

            const rawUVs = points.map(p => getUV(p));
            const normUVs = normalizeUVs(rawUVs);
            const pixPoints = normUVs.map(({ u, v }) => ({
                x: Math.round(((u % 1.0 + 1.0) % 1.0) * (biomeWidth - 1)),
                y: Math.round(Math.max(0, Math.min(1, v)) * (biomeHeight - 1))
            }));

            let minX = biomeWidth, maxX = 0, minY = biomeHeight, maxY = 0;
            pixPoints.forEach(p => {
                minX = Math.min(minX, p.x); maxX = Math.max(maxX, p.x);
                minY = Math.min(minY, p.y); maxY = Math.max(maxY, p.y);
            });
            minX = Math.max(0, minX - 1); minY = Math.max(0, minY - 1);
            maxX = Math.min(biomeWidth - 1, maxX + 1);
            maxY = Math.min(biomeHeight - 1, maxY + 1);
            const w = maxX - minX + 1;
            const h = maxY - minY + 1;
            if (w <= 0 || h <= 0) return;

            const maskCanvas = document.createElement('canvas');
            maskCanvas.width = w; maskCanvas.height = h;
            const maskCtx = maskCanvas.getContext('2d');
            maskCtx.fillStyle = 'white';
            maskCtx.beginPath();
            pixPoints.forEach((p, i) => {
                const lx = p.x - minX, ly = p.y - minY;
                if (i === 0) maskCtx.moveTo(lx, ly);
                else maskCtx.lineTo(lx, ly);
            });
            maskCtx.closePath();
            maskCtx.fill();
            const maskData = maskCtx.getImageData(0, 0, w, h).data;

            let newCapture = 0, stolen = 0;
            for (let ly = 0; ly < h; ly++) {
                for (let lx = 0; lx < w; lx++) {
                    const mi = (ly * w + lx) * 4;
                    if (maskData[mi] < 128) continue;

                    const gx = minX + lx, gy = minY + ly;
                    if (!isLandPixelSingle(gx, gy)) continue;

                    const oi   = gy * biomeWidth + gx;
                    const prev = ownershipMap[oi];

                    if (prev === 0) {
                        ownershipMap[oi] = playerIdx + 1;
                        playerLandPixels[playerIdx]++;
                        newCapture++;
                    } else if (prev === otherIdx + 1) {
                        ownershipMap[oi] = playerIdx + 1;
                        playerLandPixels[otherIdx]--;
                        playerLandPixels[playerIdx]++;
                        newCapture++;
                        stolen++;
                    }
                }
            }

            if (newCapture <= 0) return;

            repaintRegion(minX, minY, maxX, maxY);
            updateTerritoryScores();

            if (playerIdx === 0) gameState.player1.loops++;
            else                 gameState.player2.loops++;
            updateStats();

            const pct = (newCapture / totalLandPixels * 100).toFixed(2);
            const mid = points[Math.floor(points.length / 2)];
            let msg = `+${pct}%`;
            if (stolen > 0) {
                msg = `⚔️ 탈취! +${pct}%  (${(stolen / totalLandPixels * 100).toFixed(2)}% 강탈)`;
                playSound('steal');
                showFloatingText(msg, mid, '#FFD700');
            } else {
                playSound('capture');
                showFloatingText(msg, mid, '#72D27E');
            }
        }

        // ==========================================
        // BIOME TEXTURE LOAD
        // ==========================================
        let biomeReady = false, gameReadyCallback = null;

        const biomeImg = new Image();
        biomeImg.crossOrigin = 'Anonymous';
        biomeImg.src = 'https://raw.githubusercontent.com/mrdoob/three.js/master/examples/textures/planets/earth_specular_2048.jpg';
        biomeImg.onload = () => {
            try {
                const c = document.createElement('canvas');
                biomeWidth = c.width = biomeImg.width;
                biomeHeight = c.height = biomeImg.height;
                const ctx = c.getContext('2d');
                ctx.drawImage(biomeImg, 0, 0);
                biomeData = ctx.getImageData(0, 0, biomeWidth, biomeHeight).data;
                initOverlay();
            } catch(e) {
                console.warn('[GlobeStriker] biome CORS 오류 — 육지/바다 구분 불가:', e);
            }
            biomeReady = true;
            if (gameReadyCallback) { const cb = gameReadyCallback; gameReadyCallback = null; cb(); }
        };
        biomeImg.onerror = () => {
            console.warn('[GlobeStriker] biome 이미지 로드 실패 — 모든 픽셀을 육지로 처리');
            biomeReady = true;
            if (gameReadyCallback) { const cb = gameReadyCallback; gameReadyCallback = null; cb(); }
        };

        // ==========================================
        // PLAYERS
        // ==========================================
        const players = [];
        function createPlayer(colorHex, position) {
            const body = new CANNON.Body({
                mass: CONFIG.mass,
                shape: new CANNON.Sphere(CONFIG.playerRadius),
                material: physicsMaterial,
                linearDamping: CONFIG.damping,
                angularDamping: 0.5,
            });
            body.position.copy(position);
            world.addBody(body);

            const mesh = new THREE.Mesh(
                new THREE.SphereGeometry(CONFIG.playerRadius, 32, 32),
                new THREE.MeshToonMaterial({ color: colorHex })
            );
            scene.add(mesh);

            const hitBox = new THREE.Mesh(
                new THREE.SphereGeometry(CONFIG.playerRadius * 2.5, 16, 16),
                new THREE.MeshBasicMaterial({ visible: false })
            );
            mesh.add(hitBox);

            return { body, mesh, hitBox,
                lastTrailPos: new THREE.Vector3(position.x, position.y, position.z),
                currentSegment: [],
                landSegments:   [],
            };
        }

        players.push(createPlayer(0xFF4757, new CANNON.Vec3(0, CONFIG.earthRadius + CONFIG.playerRadius + 0.05, 0)));
        players.push(createPlayer(0x5352ED, new CANNON.Vec3(0, -(CONFIG.earthRadius + CONFIG.playerRadius + 0.05), 0)));

        // ==========================================
        // CLOUDS
        // ==========================================
        const cloudGroup = new THREE.Group();
        scene.add(cloudGroup);
        const cloudMat = new THREE.MeshBasicMaterial({ color: 0xFFFFFF, transparent: true, opacity: 0.6 });
        for (let i = 0; i < 25; i++) {
            const cloud = new THREE.Mesh(new THREE.IcosahedronGeometry(0.2 + Math.random() * 0.15, 0), cloudMat);
            const radius = CONFIG.earthRadius + 0.6 + Math.random() * 0.5;
            cloud.position.setFromSphericalCoords(radius, Math.random() * Math.PI, Math.random() * Math.PI * 2);
            cloud.lookAt(0, 0, 0);
            cloud.scale.set(1 + Math.random() * 0.3, 0.5 + Math.random() * 0.2, 0.7);
            cloudGroup.add(cloud);
        }

        // ==========================================
        // TRAIL SYSTEMS
        // ==========================================
        const TRAIL_MAX = 2000;

        function createTrailSystem(color) {
            const geo = new THREE.SphereGeometry(0.03, 8, 8);
            const mat = new THREE.MeshBasicMaterial({ color, transparent: true, opacity: 0.75 });
            const mesh = new THREE.InstancedMesh(geo, mat, TRAIL_MAX);
            mesh.instanceMatrix.setUsage(THREE.DynamicDrawUsage);
            scene.add(mesh);
            return { mesh, count: 0, dummy: new THREE.Object3D() };
        }
        const trail1 = createTrailSystem(0xFF4757);
        const trail2 = createTrailSystem(0x5352ED);
        const trails = [trail1, trail2];

        // ==========================================
        // LOOP DETECTION (개선 버전)
        // ==========================================
        function checkLoop(playerIdx, newPos) {
            const player = players[playerIdx];
            const currSeg = player.currentSegment;
            const prevSegs = player.landSegments;

            // 동일 세그먼트 내 루프 검사 (마지막 점 제외)
            if (currSeg.length >= 3) {
                for (let i = 0; i < currSeg.length - 1; i++) {
                    if (newPos.distanceTo(currSeg[i]) < CONFIG.captureRadius) {
                        const loopPath = currSeg.slice(i);
                        createTerritoryArea(loopPath, playerIdx);
                        player.landSegments = [];
                        player.currentSegment = [];
                        return true;
                    }
                }
            }

            // 이전 세그먼트와 연결 검사
            for (let si = 0; si < prevSegs.length; si++) {
                const seg = prevSegs[si];
                for (let pi = 0; pi < seg.length; pi++) {
                    if (newPos.distanceTo(seg[pi]) < CONFIG.captureRadius) {
                        const loopPath = [];
                        for (let k = pi; k < seg.length; k++) loopPath.push(seg[k]);
                        for (let si2 = si + 1; si2 < prevSegs.length; si2++) {
                            prevSegs[si2].forEach(p => loopPath.push(p));
                        }
                        currSeg.forEach(p => loopPath.push(p));
                        createTerritoryArea(loopPath, playerIdx);
                        player.landSegments = [];
                        player.currentSegment = [];
                        return true;
                    }
                }
            }
            return false;
        }

        // ==========================================
        // ADD TRAIL + 잉크 시스템
        // ==========================================
        function addTrail(idx, pos) {
            const player  = players[idx];
            const psState = idx === 0 ? gameState.player1 : gameState.player2;
            const onLand  = getBiome(pos) === 'LAND';

            if (!onLand) {
                if (player.currentSegment.length > 0) {
                    player.landSegments.push([...player.currentSegment]);
                    player.currentSegment = [];

                    psState.ink = Math.max(0, psState.ink - CONFIG.inkOceanPenalty);
                    updateInkUI();

                    const mat = trails[idx].mesh.material;
                    mat.opacity = 0.15;
                    setTimeout(() => { mat.opacity = 0.75; }, 500);
                }
                return;
            }

            if (psState.ink <= 0) return;

            psState.ink = Math.max(0, psState.ink - CONFIG.inkLandCost);
            updateInkUI();

            const sys = trails[idx];
            const ringIdx = sys.count % TRAIL_MAX;
            sys.dummy.position.copy(pos);
            sys.dummy.position.setLength(CONFIG.earthRadius + 0.02);
            sys.dummy.lookAt(0, 0, 0);
            sys.dummy.rotateZ(Math.random() * Math.PI);
            const s = 0.8 + Math.random() * 0.4;
            sys.dummy.scale.set(s, s, 1);
            sys.dummy.updateMatrix();
            sys.mesh.setMatrixAt(ringIdx, sys.dummy.matrix);
            sys.mesh.instanceMatrix.needsUpdate = true;
            sys.count++;

            player.currentSegment.push(pos.clone());

            // 루프 감지 실행 (새 점 추가 후)
            checkLoop(idx, pos.clone());
        }

        // ==========================================
