        function updateTimer() {
            if (gameState.timeRemaining <= 0) { endGame(); return; }
            gameState.timeRemaining--;
            const m = Math.floor(gameState.timeRemaining / 60);
            const s = gameState.timeRemaining % 60;
            elements.timer.textContent = `${m}:${s.toString().padStart(2, '0')}`;
            elements.timer.style.color = gameState.timeRemaining <= 30 ? 'var(--player1-color)' : 'var(--text-dark)';
        }

        function endGame() {
            gameActive = false;
            clearInterval(gameState._turnTimer);
            const countdown = document.getElementById('turn-countdown');
            if (countdown) countdown.style.display = 'none';
            const p1 = gameState.player1.territory;
            const p2 = gameState.player2.territory;
            let winText;
            if (Math.abs(p1 - p2) < 0.01) winText = '🤝 무승부!';
            else winText = `🏆 Player ${p1 > p2 ? 1 : 2} 우승!`;
            document.getElementById('winner-text').textContent = winText;
            document.getElementById('winner-text').style.color = p1 > p2 ? 'var(--player1-color)' : 'var(--player2-color)';
            document.getElementById('final-p1').textContent = `${p1.toFixed(2)}%`;
            document.getElementById('final-p2').textContent = `${p2.toFixed(2)}%`;
