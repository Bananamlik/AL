        function updateInkUI() {
            const i1 = gameState.player1.ink, i2 = gameState.player2.ink;
            const bar1 = document.getElementById('ink-bar-p1');
            const bar2 = document.getElementById('ink-bar-p2');
            const lbl1 = document.getElementById('ink-p1');
            const lbl2 = document.getElementById('ink-p2');
            if (bar1) bar1.style.width = `${i1}%`;
            if (bar2) bar2.style.width = `${i2}%`;
