        }

        // ==========================================
        // FORCE CALCULATION & TRAJECTORY PREVIEW
        // ==========================================
        const raycaster = new THREE.Raycaster();
        const mouse = new THREE.Vector2();

        function getIntersects(clientX, clientY, objects) {
            mouse.x =  (clientX / window.innerWidth)  * 2 - 1;
            mouse.y = -(clientY / window.innerHeight) * 2 + 1;
            raycaster.setFromCamera(mouse, camera);
            return raycaster.intersectObjects(objects, true);
        }

        function calculateForce(currentX, currentY, startX, startY) {
            const deltaX = currentX - startX;
            const deltaY = currentY - startY;
            const player = players[gameState.currentPlayer - 1];
            const surfaceNormal = player.mesh.position.clone().normalize();
            const camRight = new THREE.Vector3(1, 0, 0).applyQuaternion(camera.quaternion);
            const camUp    = new THREE.Vector3(0, 1, 0).applyQuaternion(camera.quaternion);
            const forceVector = new THREE.Vector3()
                .addScaledVector(camRight, -deltaX)
                .addScaledVector(camUp,     deltaY);
            forceVector.sub(surfaceNormal.multiplyScalar(forceVector.dot(surfaceNormal)));
            return { forceDir: forceVector.normalize(), deltaX, deltaY };
        }

        function updateTrajectory(startPos, impulseVector) {
            const dt = 0.016;
            const simPos = startPos.clone();
            const simVel = impulseVector.clone().multiplyScalar(dt / CONFIG.mass);
            const positions = trajLine.geometry.attributes.position.array;
            const omega = new THREE.Vector3(0, 1, 0);

            for (let i = 0; i < TRAJ_POINTS; i++) {
                positions[i * 3]     = simPos.x;
                positions[i * 3 + 1] = simPos.y;
                positions[i * 3 + 2] = simPos.z;

                const gravDir = simPos.clone().normalize().negate();
                const gravAcc = gravDir.multiplyScalar(CONFIG.gravity * dt * dt);

                const coriolisAcc = simVel.clone().cross(omega)
                    .multiplyScalar(CONFIG.coriolisFactor * dt);

                simVel.add(gravAcc).add(coriolisAcc);
                simVel.multiplyScalar(1 - CONFIG.damping * dt);
                simPos.add(simVel);

                if (simPos.length() < CONFIG.earthRadius + CONFIG.playerRadius) {
                    simPos.setLength(CONFIG.earthRadius + CONFIG.playerRadius + 0.02);
                }
            }
            trajLine.geometry.attributes.position.needsUpdate = true;
            trajLine.computeLineDistances();
        }

        // ==========================================
        // INPUT: POINTER EVENTS
        // ==========================================
        let isDragging = false;
        const dragStart = new THREE.Vector2();

        function onPointerDown(e) {
            if (!gameActive || !gameState.isPlanning || gameState.hasShot) return;
            const clientX = e.clientX ?? e.touches?.[0]?.clientX;
            const clientY = e.clientY ?? e.touches?.[0]?.clientY;
            if (clientX == null) return;
            const player = players[gameState.currentPlayer - 1];
            const hits = getIntersects(clientX, clientY, [player.mesh]);
            if (hits.length > 0) {
                isDragging = true;
                controls.enabled = false;
                dragStart.set(clientX, clientY);
                aimGroup.visible = true;
                trajLine.visible = true;
                aimGroup.position.copy(player.mesh.position);
                elements.powerGauge.classList.add('visible');
            }
        }

        function onPointerMove(e) {
            const clientX = e.clientX ?? e.touches?.[0]?.clientX;
            const clientY = e.clientY ?? e.touches?.[0]?.clientY;
            if (clientX == null) return;

            if (!isDragging) {
                const player = players[gameState.currentPlayer - 1];
                const hits = getIntersects(clientX, clientY, [player.mesh]);
                document.body.style.cursor = hits.length > 0 ? 'grab' : 'default';
                return;
            }
            document.body.style.cursor = 'grabbing';

            const { forceDir } = calculateForce(clientX, clientY, dragStart.x, dragStart.y);
            const dx = clientX - dragStart.x, dy = clientY - dragStart.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            const MAX_DRAG = 250;
            const power = Math.min(dist, MAX_DRAG) / MAX_DRAG;

            arrow.setDirection(forceDir);
            arrow.setLength(1 + power * 2, 0.4, 0.3);
            arrow.setColor(new THREE.Color().setHSL(0.3 * (1 - power), 1, 0.5));

            const tailDir = forceDir.clone().negate();
            tailLine.lookAt(tailLine.position.clone().add(tailDir));
            tailLine.scale.z = power * 3.5;

            const impulse = forceDir.clone().multiplyScalar(power * CONFIG.shootForce);
            updateTrajectory(players[gameState.currentPlayer - 1].mesh.position, impulse);
            elements.powerFill.style.width = `${power * 100}%`;
            if (power > 0.05) playSound('charge');
        }

        function onPointerUp(e) {
            if (!isDragging) return;
            isDragging = false;
            controls.enabled = true;
            aimGroup.visible = false;
            trajLine.visible = false;
            elements.powerGauge.classList.remove('visible');
            elements.powerFill.style.width = '0%';
            document.body.style.cursor = 'default';

            const clientX = e.clientX ?? e.changedTouches?.[0]?.clientX;
            const clientY = e.clientY ?? e.changedTouches?.[0]?.clientY;
            if (clientX == null) return;

            const { forceDir } = calculateForce(clientX, clientY, dragStart.x, dragStart.y);
            const dx = clientX - dragStart.x, dy = clientY - dragStart.y;
            const dist = Math.sqrt(dx*dx + dy*dy);
            const power = Math.min(dist, 250) / 250;

            if (power < 0.1) return;

            const impulse = forceDir.clone().multiplyScalar(power * CONFIG.shootForce);
            const player = players[gameState.currentPlayer - 1];

            player.body.applyImpulse(
                new CANNON.Vec3(impulse.x, impulse.y, impulse.z),
                player.body.position
            );
            gameState.isFollowing = true;
            playSound('shoot');
            gameState.hasShot = true;
            gameState.isPlanning = false;
            clearInterval(gameState._turnTimer);
            const countdown = document.getElementById('turn-countdown');
            if (countdown) countdown.style.display = 'none';
            if (gameState.currentPlayer === 1) gameState.player1.shots++;
            else gameState.player2.shots++;
            updateStats();
        }

        renderer.domElement.addEventListener('pointerdown',  onPointerDown, { passive: false });
        window.addEventListener('pointermove', onPointerMove, { passive: true });
        window.addEventListener('pointerup',   onPointerUp);
        renderer.domElement.addEventListener('touchstart', e => { if(isDragging) e.preventDefault(); }, { passive: false });
        renderer.domElement.addEventListener('touchmove',  e => { if(isDragging) e.preventDefault(); }, { passive: false });

        // ==========================================
        // PHYSICS FORCES
        // ==========================================
        function applyPhysicsForces(body) {
            const gravDir = body.position.clone().negate().unit();
            body.applyForce(gravDir.scale(CONFIG.gravity * body.mass), body.position);

            if (body.velocity.lengthSquared() > 0.1) {
                const vel = new THREE.Vector3(body.velocity.x, body.velocity.y, body.velocity.z);
                const omega = new THREE.Vector3(0, 1, 0);

                const posN = new THREE.Vector3(body.position.x, body.position.y, body.position.z).normalize();
                const lat = Math.asin(Math.max(-1, Math.min(1, posN.y)));
                const latScale = Math.abs(Math.sin(lat));

                const coriolis = new THREE.Vector3().crossVectors(vel, omega)
                    .multiplyScalar(CONFIG.coriolisFactor * (0.3 + 0.7 * latScale));
                body.applyForce(
                    new CANNON.Vec3(coriolis.x, coriolis.y, coriolis.z),
                    body.position
                );
            }
        }

        world.addEventListener('postStep', () => {
            const p1 = new THREE.Vector3().copy(players[0].body.position);
            const p2 = new THREE.Vector3().copy(players[1].body.position);
            if (p1.distanceTo(p2) < CONFIG.playerRadius * 2.5) {
                gameState.collisions++;
                updateStats();
            }
        });

